{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.+\\.html)$",
      "dest": "public/$1"
    },
    {
      "src": "/(.+\\.png)$",
      "dest": "public/$1"
    },
    {
      "src": "/(.+\\.css)$",
      "dest": "public/$1"
    },
    {
      "src": "/(.+\\.js)$",
      "dest": "public/$1"
    },
    {
      "src": "/",
      "dest": "public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
