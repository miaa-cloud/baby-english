{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/qrcode.html",
      "dest": "public/qrcode.html"
    },
    {
      "src": "/qr-code.png",
      "dest": "public/qr-code.png"
    },
    {
      "src": "/deployment-success.html",
      "dest": "public/deployment-success.html"
    },
    {
      "src": "/click-test.html",
      "dest": "public/click-test.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
